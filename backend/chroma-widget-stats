#!/usr/bin/env bash

set -u
set -o pipefail

read_cpu() {
    awk '/^cpu / { idle=$5+$6; total=0; for (i=2; i<=NF; i++) total+=$i; print total, idle; exit }' /proc/stat
}

read -r total_a idle_a < <(read_cpu)
sleep 0.18
read -r total_b idle_b < <(read_cpu)

delta_total=$((total_b - total_a))
delta_idle=$((idle_b - idle_a))
if test "$delta_total" -gt 0; then
    cpu="$(awk -v total="$delta_total" -v idle="$delta_idle" 'BEGIN { printf "%.2f", (total-idle)*100/total }')"
else
    cpu=0
fi

memory="$(awk '
    /^MemTotal:/ { total=$2 }
    /^MemAvailable:/ { available=$2 }
    END {
        if (total > 0) printf "%.2f", (total-available)*100/total;
        else print "0";
    }
' /proc/meminfo)"

gpu=0
gpu_temp=-1
gpu_name="GPU"

if command -v nvidia-smi >/dev/null 2>&1; then
    line="$(nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,name --format=csv,noheader,nounits 2>/dev/null | head -n1 || true)"
    if test -n "$line"; then
        gpu="$(cut -d, -f1 <<<"$line" | xargs)"
        gpu_temp="$(cut -d, -f2 <<<"$line" | xargs)"
        gpu_name="$(cut -d, -f3- <<<"$line" | xargs)"
    fi
elif test -r /sys/class/drm/card0/device/gpu_busy_percent; then
    gpu="$(cat /sys/class/drm/card0/device/gpu_busy_percent 2>/dev/null || printf 0)"
fi

cpu_temp=-1
for sensor in /sys/class/thermal/thermal_zone*/temp; do
    test -r "$sensor" || continue
    value="$(cat "$sensor" 2>/dev/null || true)"
    case "$value" in
        ''|*[!0-9]*) continue ;;
    esac
    if test "$value" -gt 1000; then
        cpu_temp="$(awk -v value="$value" 'BEGIN { printf "%.1f", value/1000 }')"
    else
        cpu_temp="$value"
    fi
    break
done

if command -v jq >/dev/null 2>&1; then
    jq -n \
        --argjson cpu "${cpu:-0}" \
        --argjson gpu "${gpu:-0}" \
        --argjson memory "${memory:-0}" \
        --argjson cpuTemperature "${cpu_temp:--1}" \
        --argjson gpuTemperature "${gpu_temp:--1}" \
        --arg gpuName "$gpu_name" \
        '{cpu:$cpu,gpu:$gpu,memory:$memory,cpuTemperature:$cpuTemperature,gpuTemperature:$gpuTemperature,gpuName:$gpuName}'
else
    printf '{"cpu":%s,"gpu":%s,"memory":%s,"cpuTemperature":%s,"gpuTemperature":%s,"gpuName":"%s"}\n' \
        "${cpu:-0}" "${gpu:-0}" "${memory:-0}" "${cpu_temp:--1}" "${gpu_temp:--1}" "${gpu_name//\"/}"
fi
