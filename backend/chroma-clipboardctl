#!/usr/bin/env bash

set -u
set -o pipefail

home="${HOME:?HOME is not set}"
cache_root="${XDG_CACHE_HOME:-$home/.cache}/chroma-shell/clipboard"
mkdir -p "$cache_root"

json_error() {
    jq -n --arg message "$1" '{ok:false,message:$message}'
}

json_ok() {
    jq -n --arg message "$1" '{ok:true,message:$message}'
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || {
        json_error "REQUIRED COMMAND IS MISSING: $1"
        return 1
    }
}

record_for_id() {
    local id="$1"
    local line line_id

    while IFS= read -r line; do
        line_id="${line%%$'\t'*}"
        if test "$line_id" = "$id"; then
            printf '%s\n' "$line"
            return 0
        fi
    done < <(cliphist list 2>/dev/null)

    return 1
}

capabilities() {
    local cliphist_ok=false wl_copy_ok=false wl_paste_ok=false hyprctl_ok=false

    command -v cliphist >/dev/null 2>&1 && cliphist_ok=true
    command -v wl-copy >/dev/null 2>&1 && wl_copy_ok=true
    command -v wl-paste >/dev/null 2>&1 && wl_paste_ok=true
    command -v hyprctl >/dev/null 2>&1 && hyprctl_ok=true

    jq -n \
        --argjson cliphist "$cliphist_ok" \
        --argjson wlCopy "$wl_copy_ok" \
        --argjson wlPaste "$wl_paste_ok" \
        --argjson hyprctl "$hyprctl_ok" \
        '{ok:($cliphist and $wlCopy and $wlPaste),cliphist:$cliphist,wlCopy:$wlCopy,wlPaste:$wlPaste,hyprctl:$hyprctl}'
}

list_entries() {
    local query="${1:-}"
    local limit="${2:-60}"
    local line id preview kind mime detail count=0
    local lowered_query lowered_preview

    require_command cliphist || return 1
    require_command jq || return 1

    if ! [[ "$limit" =~ ^[0-9]+$ ]]; then
        limit=60
    fi
    if test "$limit" -lt 1; then
        limit=1
    elif test "$limit" -gt 200; then
        limit=200
    fi

    lowered_query="${query,,}"

    while IFS= read -r line; do
        test -n "$line" || continue

        id="${line%%$'\t'*}"
        if test "$line" = "$id"; then
            preview=""
        else
            preview="${line#*$'\t'}"
        fi

        [[ "$id" =~ ^[0-9]+$ ]] || continue

        lowered_preview="${preview,,}"
        if test -n "$lowered_query" \
            && [[ "$lowered_preview" != *"$lowered_query"* ]] \
            && [[ "$id" != *"$lowered_query"* ]]
        then
            continue
        fi

        kind="text"
        mime="text/plain"
        detail="TEXT ENTRY"

        if [[ "$preview" == "[[ binary data"* ]] \
            || [[ "$lowered_preview" == *"image/"* ]]
        then
            kind="image"
            mime="$(grep -oE 'image/[A-Za-z0-9.+-]+' <<<"$preview" | head -n1 || true)"
            : "${mime:=image/unknown}"
            detail="$(grep -oE '[0-9]{2,5}x[0-9]{2,5}' <<<"$preview" | head -n1 || true)"
            : "${detail:=IMAGE ENTRY}"
        fi

        jq -n \
            --arg id "$id" \
            --arg preview "$preview" \
            --arg kind "$kind" \
            --arg mime "$mime" \
            --arg detail "$detail" \
            '{id:$id,preview:$preview,kind:$kind,mime:$mime,detail:$detail}'

        count=$((count + 1))
        test "$count" -ge "$limit" && break
    done < <(cliphist list 2>/dev/null) | jq -s '{ok:true,entries:.}'
}

inspect_entry() {
    local id="${1:-}"
    local kind="${2:-text}"
    local record temporary output

    require_command cliphist || return 1
    require_command jq || return 1

    [[ "$id" =~ ^[0-9]+$ ]] || {
        json_error "INVALID CLIPBOARD ENTRY"
        return 1
    }

    record="$(record_for_id "$id" 2>/dev/null || true)"
    test -n "$record" || {
        json_error "CLIPBOARD ENTRY NO LONGER EXISTS"
        return 1
    }

    temporary="$(mktemp "$cache_root/inspect-${id}.XXXXXX")"
    if ! printf '%s\n' "$record" | cliphist decode >"$temporary" 2>/dev/null; then
        rm -f "$temporary"
        json_error "CLIPBOARD ENTRY COULD NOT BE DECODED"
        return 1
    fi

    if test "$kind" = "image"; then
        output="$cache_root/preview-${id}.image"
        mv "$temporary" "$output"
        jq -n \
            --arg id "$id" \
            --arg path "file://$output" \
            '{ok:true,id:$id,kind:"image",path:$path,text:""}'
        return 0
    fi

    jq -Rs \
        --arg id "$id" \
        '{ok:true,id:$id,kind:"text",path:"",text:(if length > 24000 then .[0:24000] + "\n\n[TRUNCATED]" else . end)}' \
        <"$temporary"
    rm -f "$temporary"
}

copy_entry() {
    local id="${1:-}"
    local record

    require_command cliphist || return 1
    require_command wl-copy || return 1

    [[ "$id" =~ ^[0-9]+$ ]] || {
        json_error "INVALID CLIPBOARD ENTRY"
        return 1
    }

    record="$(record_for_id "$id" 2>/dev/null || true)"
    test -n "$record" || {
        json_error "CLIPBOARD ENTRY NO LONGER EXISTS"
        return 1
    }

    if ! printf '%s\n' "$record" | cliphist decode | wl-copy; then
        json_error "CLIPBOARD ENTRY COULD NOT BE RESTORED"
        return 1
    fi

    json_ok "CLIPBOARD ENTRY RESTORED"
}

delete_entry() {
    local id="${1:-}"
    local record

    require_command cliphist || return 1

    [[ "$id" =~ ^[0-9]+$ ]] || {
        json_error "INVALID CLIPBOARD ENTRY"
        return 1
    }

    record="$(record_for_id "$id" 2>/dev/null || true)"
    test -n "$record" || {
        json_error "CLIPBOARD ENTRY NO LONGER EXISTS"
        return 1
    }

    if ! printf '%s\n' "$record" | cliphist delete >/dev/null 2>&1; then
        json_error "CLIPBOARD ENTRY COULD NOT BE DELETED"
        return 1
    fi

    rm -f "$cache_root/preview-${id}.image"
    json_ok "CLIPBOARD ENTRY DELETED"
}

clear_history() {
    require_command cliphist || return 1

    if ! cliphist wipe >/dev/null 2>&1; then
        json_error "CLIPBOARD HISTORY COULD NOT BE CLEARED"
        return 1
    fi

    rm -f "$cache_root"/preview-*.image "$cache_root"/inspect-* 2>/dev/null || true
    json_ok "CLIPBOARD HISTORY CLEARED"
}

send_paste() {
    command -v hyprctl >/dev/null 2>&1 || return 0
    sleep 0.18
    hyprctl dispatch sendshortcut "CTRL, V, activewindow" >/dev/null 2>&1 || true
}

watch_clipboard() {
    local type="$1"

    command -v wl-paste >/dev/null 2>&1 || exit 127
    command -v cliphist >/dev/null 2>&1 || exit 127

    exec wl-paste --type "$type" --watch cliphist store
}

case "${1:-help}" in
    capabilities)
        capabilities
        ;;
    list)
        shift
        list_entries "$@"
        ;;
    inspect)
        shift
        inspect_entry "$@"
        ;;
    copy)
        shift
        copy_entry "$@"
        ;;
    delete)
        shift
        delete_entry "$@"
        ;;
    clear)
        clear_history
        ;;
    send-paste)
        send_paste
        ;;
    watch-text)
        watch_clipboard text
        ;;
    watch-image)
        watch_clipboard image
        ;;
    *)
        printf 'Usage: %s {capabilities|list|inspect|copy|delete|clear|send-paste|watch-text|watch-image}\n' "$0" >&2
        exit 2
        ;;
esac
