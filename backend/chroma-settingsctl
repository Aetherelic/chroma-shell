#!/usr/bin/env bash

set -u

home="${HOME:?HOME is not set}"
xdg_config="${XDG_CONFIG_HOME:-$home/.config}"
xdg_data="${XDG_DATA_HOME:-$home/.local/share}"
xdg_state="${XDG_STATE_HOME:-$home/.local/state}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
project="$(cd -- "$script_dir/.." && pwd -P)"
state="$xdg_state/chroma-shell"
settings_root="$xdg_data/chroma-settings"
snapshots="$settings_root/snapshots"
backups="$xdg_data"
display_root="$settings_root/display"
display_config="$xdg_config/hypr/conf.d/chroma-displays.conf"
style_config="$xdg_config/hypr/conf.d/chroma-style.conf"
hyprland_config="$xdg_config/hypr/hyprland.conf"
pending_file="$display_root/pending"
applications_root="$settings_root/applications"
autostart_root="$xdg_config/autostart"
mimeapps_file="$xdg_config/mimeapps.list"
applications_backups="$applications_root/backups"
config_root="$settings_root/config"
config_restore_root="$config_root/restore"
settings_file="$xdg_config/chroma/settings.json"
wallpaper_root="$xdg_config/chroma-wallpaper"
preview_log="$state/preview.log"

mkdir -p \
    "$settings_root" \
    "$snapshots" \
    "$display_root" \
    "$applications_root" \
    "$applications_backups" \
    "$config_root" \
    "$config_restore_root"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "CHROMA//SETTINGS" "$1"
    fi
}

open_path() {
    local path="$1"

    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$path" >/dev/null 2>&1 &
    elif command -v thunar >/dev/null 2>&1; then
        thunar "$path" >/dev/null 2>&1 &
    fi
}

open_file() {
    local file="$1"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    if command -v code >/dev/null 2>&1; then
        code "$file" >/dev/null 2>&1 &
    elif command -v kitty >/dev/null 2>&1; then
        kitty -e "${EDITOR:-nano}" "$file" >/dev/null 2>&1 &
    else
        open_path "$file"
    fi
}

system_json() {
    local hostname_value os kernel uptime_value generation cpu gpu memory storage displays hyprland quickshell chroma_pid

    hostname_value="$(hostname 2>/dev/null || printf 'unknown')"
    os="$(nixos-version 2>/dev/null || grep '^PRETTY_NAME=' /etc/os-release 2>/dev/null | cut -d= -f2- | tr -d '"')"
    kernel="$(uname -r 2>/dev/null || printf 'unknown')"
    uptime_value="$(uptime -p 2>/dev/null | sed 's/^up //' || printf 'unknown')"
    generation="$(basename "$(readlink -f /run/current-system 2>/dev/null)" 2>/dev/null || printf 'unknown')"
    cpu="$(lscpu 2>/dev/null | awk -F: '/Model name/ {sub(/^[ \t]+/, "", $2); print $2; exit}')"
    gpu="$(lspci 2>/dev/null | awk -F': ' '/VGA compatible controller|3D controller/ {print $2; exit}')"
    memory="$(free -h 2>/dev/null | awk '/^Mem:/ {print $3 " used / " $2 " total"}')"
    storage="$(df -h / 2>/dev/null | awk 'NR==2 {print $3 " used / " $2 " total (" $5 ")"}')"
    displays="$(hyprctl monitors -j 2>/dev/null | jq -r 'length | tostring + " connected"' 2>/dev/null || printf 'unknown')"
    hyprland="$(hyprctl version 2>/dev/null | awk 'NR==1 {print; exit}')"
    quickshell="$(quickshell --version 2>/dev/null | head -n1 || printf 'unknown')"
    chroma_pid="$("$project/preview.sh" status 2>/dev/null | awk '/PID/ {print $2; exit}')"

    : "${cpu:=unknown}" "${gpu:=unknown}" "${memory:=unknown}" "${storage:=unknown}" "${hyprland:=unknown}" "${quickshell:=unknown}" "${chroma_pid:=unknown}"

    jq -n \
        --arg hostname "$hostname_value" \
        --arg os "$os" \
        --arg kernel "$kernel" \
        --arg uptime "$uptime_value" \
        --arg generation "$generation" \
        --arg cpu "$cpu" \
        --arg gpu "$gpu" \
        --arg memory "$memory" \
        --arg storage "$storage" \
        --arg displays "$displays" \
        --arg hyprland "$hyprland" \
        --arg quickshell "$quickshell" \
        --arg chromaPid "$chroma_pid" \
        '{hostname:$hostname, os:$os, kernel:$kernel, uptime:$uptime, generation:$generation, cpu:$cpu, gpu:$gpu, memory:$memory, storage:$storage, displays:$displays, hyprland:$hyprland, quickshell:$quickshell, chromaPid:$chromaPid}'
}

report() {
    printf '=== CHROMA HEALTH ===\n'
    if command -v chroma-healthcheck >/dev/null 2>&1; then
        chroma-healthcheck 2>&1
    else
        "$project/preview.sh" status 2>&1
        tail -n 80 "$state/preview.log" 2>/dev/null || true
    fi

    printf '\n=== SYSTEM ===\n'
    system_json | jq . 2>/dev/null || system_json

    printf '\n=== MONITORS ===\n'
    hyprctl monitors all -j 2>/dev/null | jq . 2>/dev/null || true

    printf '\n=== CONFIGURATION ===\n'
    config_status_json | jq . 2>/dev/null || config_status_json
}

ensure_display_source() {
    local source_line='source = ~/.config/hypr/conf.d/chroma-displays.conf'

    mkdir -p "$(dirname "$hyprland_config")" "$(dirname "$display_config")"
    touch "$hyprland_config"

    if ! grep -Fqx "$source_line" "$hyprland_config" 2>/dev/null; then
        printf '\n%s\n' "$source_line" >> "$hyprland_config"
    fi
}

monitor_spec_from_json() {
    local row="$1"
    local name width height refresh x y scale transform vrr disabled mode

    name="$(jq -r '.name' <<<"$row")"
    disabled="$(jq -r '.disabled // false' <<<"$row")"

    if test "$disabled" = "true"; then
        printf '%s,disable\n' "$name"
        return
    fi

    width="$(jq -r '.width' <<<"$row")"
    height="$(jq -r '.height' <<<"$row")"
    refresh="$(jq -r '.refreshRate' <<<"$row")"
    x="$(jq -r '.x' <<<"$row")"
    y="$(jq -r '.y' <<<"$row")"
    scale="$(jq -r '.scale' <<<"$row")"
    transform="$(jq -r '.transform // 0' <<<"$row")"
    vrr="$(jq -r 'if .vrr == true then 1 else 0 end' <<<"$row")"
    mode="${width}x${height}@${refresh}"

    printf '%s,%s,%sx%s,%s,transform,%s,vrr,%s\n' \
        "$name" "$mode" "$x" "$y" "$scale" "$transform" "$vrr"
}

apply_display_snapshot() {
    local snapshot="$1"
    local row spec
    local failed=0

    test -f "$snapshot" || return 1

    while IFS= read -r row; do
        spec="$(monitor_spec_from_json "$row")"
        if ! hyprctl keyword monitor "$spec" >/dev/null 2>&1; then
            failed=1
        fi
    done < <(jq -c '.[]' "$snapshot")

    return "$failed"
}

write_display_config() {
    local current="$1"
    local row spec temporary

    mkdir -p "$(dirname "$display_config")"
    temporary="$(mktemp "${display_config}.tmp.XXXXXX")"

    {
        printf '# CHROMA managed display configuration\n'
        printf '# Generated %s\n\n' "$(date --iso-8601=seconds)"

        while IFS= read -r row; do
            spec="$(monitor_spec_from_json "$row")"
            printf 'monitor = %s\n' "$spec"
        done < <(jq -c '.[]' "$current")

        printf '\n# Fallback for newly connected outputs.\n'
        printf 'monitor = ,preferred,auto,1\n'
    } > "$temporary"

    mv "$temporary" "$display_config"
    ensure_display_source
}

save_known_good() {
    local current="${1:-}"
    local temporary

    if test -z "$current"; then
        current="$(hyprctl monitors all -j 2>/dev/null)" || return 1
    fi

    if ! jq -e 'type == "array" and length > 0' >/dev/null 2>&1 \
        <<<"$current"
    then
        return 1
    fi

    temporary="$(mktemp "$display_root/known-good.json.tmp.XXXXXX")"
    printf '%s\n' "$current" | jq . > "$temporary"
    mv "$temporary" "$display_root/known-good.json"
}

pending_token() {
    cat "$pending_file" 2>/dev/null || true
}

clear_stale_pending() {
    local token

    token="$(pending_token)"
    if test -n "$token" && ! test -f "$display_root/$token/monitors.json"; then
        rm -f "$pending_file"
    fi
}

display_preview() {
    local name="${1:-}" mode="${2:-}" x="${3:-}" y="${4:-}"
    local scale="${5:-}" transform="${6:-}" vrr="${7:-}"
    local enabled="${8:-}"
    local monitors active_count exists mode_valid token token_dir snapshot
    local mode_cmd spec current_pending

    clear_stale_pending
    current_pending="$(pending_token)"

    if test -n "$current_pending"; then
        jq -n '{ok:false,message:"A DISPLAY PREVIEW IS ALREADY ACTIVE"}'
        return 1
    fi

    monitors="$(hyprctl monitors all -j 2>/dev/null)" || {
        jq -n '{ok:false,message:"HYPRLAND MONITOR REPORT UNAVAILABLE"}'
        return 1
    }

    if ! jq -e 'type == "array" and length > 0' >/dev/null 2>&1 \
        <<<"$monitors"
    then
        jq -n '{ok:false,message:"NO DISPLAY OUTPUTS WERE REPORTED"}'
        return 1
    fi

    exists="$(
        jq --arg name "$name" \
            '[.[] | select(.name == $name)] | length' \
            <<<"$monitors"
    )"

    if test "$exists" -ne 1; then
        jq -n '{ok:false,message:"UNKNOWN DISPLAY OUTPUT"}'
        return 1
    fi

    if ! [[ "$x" =~ ^-?[0-9]+$ \
        && "$y" =~ ^-?[0-9]+$ \
        && "$scale" =~ ^[0-9]+([.][0-9]+)?$ \
        && "$transform" =~ ^[0-7]$ \
        && "$vrr" =~ ^[01]$ \
        && "$enabled" =~ ^[01]$ ]]
    then
        jq -n '{ok:false,message:"DISPLAY VALUES FAILED VALIDATION"}'
        return 1
    fi

    if test "$x" -lt -16384 || test "$x" -gt 16384 \
        || test "$y" -lt -16384 || test "$y" -gt 16384
    then
        jq -n '{ok:false,message:"DISPLAY POSITION IS OUTSIDE THE SAFE RANGE"}'
        return 1
    fi

    if ! awk -v value="$scale" \
        'BEGIN { exit !(value >= 0.50 && value <= 4.00) }'
    then
        jq -n '{ok:false,message:"DISPLAY SCALE IS OUTSIDE THE SAFE RANGE"}'
        return 1
    fi

    if test "$enabled" = "0"; then
        active_count="$(
            jq '[.[] | select(.disabled != true)] | length' \
                <<<"$monitors"
        )"

        if test "$active_count" -le 1; then
            jq -n '{ok:false,message:"THE LAST ACTIVE OUTPUT CANNOT BE DISABLED"}'
            return 1
        fi

        spec="$name,disable"
    else
        mode_valid="$(
            jq --arg name "$name" --arg mode "$mode" \
                '[.[] | select(.name == $name) | .availableModes[]? | select(. == $mode)] | length' \
                <<<"$monitors"
        )"

        if test "$mode_valid" -ne 1; then
            jq -n '{ok:false,message:"MODE IS NOT REPORTED BY THIS DISPLAY"}'
            return 1
        fi

        mode_cmd="${mode%Hz}"
        spec="$name,$mode_cmd,${x}x${y},$scale,transform,$transform,vrr,$vrr"
    fi

    if ! test -f "$display_root/known-good.json"; then
        save_known_good "$monitors" || true
    fi

    token="$(date +%s)-$$-$RANDOM"
    token_dir="$display_root/$token"
    snapshot="$token_dir/monitors.json"
    mkdir -p "$token_dir"
    printf '%s\n' "$monitors" | jq . > "$snapshot"

    if ! hyprctl keyword monitor "$spec" >/dev/null 2>&1; then
        rm -rf "$token_dir"
        jq -n '{ok:false,message:"HYPRLAND REJECTED THE DISPLAY CONFIGURATION"}'
        return 1
    fi

    printf '%s\n' "$token" > "$pending_file"

    (
        sleep 15
        if test "$(pending_token)" = "$token"; then
            bash "$0" display-revert "$token" >/dev/null 2>&1 || true
        fi
    ) </dev/null >/dev/null 2>&1 &

    jq -n \
        --arg token "$token" \
        --argjson seconds 15 \
        '{ok:true,token:$token,seconds:$seconds,message:"TEMPORARY DISPLAY CONFIGURATION APPLIED"}'
}

display_keep() {
    local token="${1:-}" current

    if test -z "$token" || test "$(pending_token)" != "$token"; then
        printf 'NO MATCHING DISPLAY PREVIEW IS ACTIVE\n'
        return 1
    fi

    current="$(hyprctl monitors all -j 2>/dev/null)" || return 1
    save_known_good "$current" || return 1
    write_display_config "$display_root/known-good.json"

    rm -f "$pending_file"
    rm -rf "$display_root/$token"
    notify "Display configuration saved"
    printf 'DISPLAY CONFIGURATION SAVED\n'
}

display_revert() {
    local token="${1:-}" snapshot active

    if test -z "$token"; then
        printf 'DISPLAY PREVIEW TOKEN IS REQUIRED\n'
        return 1
    fi

    snapshot="$display_root/$token/monitors.json"
    if ! test -f "$snapshot"; then
        if test "$(pending_token)" = "$token"; then
            rm -f "$pending_file"
        fi
        printf 'DISPLAY PREVIEW WAS ALREADY RESTORED\n'
        return 0
    fi

    if ! apply_display_snapshot "$snapshot"; then
        printf 'DISPLAY CONFIGURATION COULD NOT BE FULLY RESTORED\n'
        return 1
    fi

    active="$(pending_token)"
    if test "$active" = "$token"; then
        rm -f "$pending_file"
    fi
    rm -rf "$display_root/$token"
    notify "Display configuration restored"
    printf 'DISPLAY CONFIGURATION RESTORED\n'
}

display_known_good() {
    local current

    current="$(hyprctl monitors all -j 2>/dev/null)" || {
        printf 'HYPRLAND MONITOR REPORT UNAVAILABLE\n'
        return 1
    }

    save_known_good "$current" || {
        printf 'KNOWN-GOOD DISPLAY SNAPSHOT COULD NOT BE WRITTEN\n'
        return 1
    }

    write_display_config "$display_root/known-good.json"
    notify "Current display layout saved as known-good"
    printf 'CURRENT DISPLAY LAYOUT SAVED AS KNOWN-GOOD\n'
}

display_restore_known_good() {
    local snapshot="$display_root/known-good.json"

    if ! test -f "$snapshot"; then
        printf 'NO KNOWN-GOOD DISPLAY LAYOUT EXISTS\n'
        return 1
    fi

    if ! apply_display_snapshot "$snapshot"; then
        printf 'KNOWN-GOOD DISPLAY LAYOUT COULD NOT BE FULLY RESTORED\n'
        return 1
    fi

    write_display_config "$snapshot"
    notify "Known-good display layout restored"
    printf 'KNOWN-GOOD DISPLAY LAYOUT RESTORED\n'
}

display_focus() {
    local name="${1:-}"
    local exists

    exists="$(
        hyprctl monitors all -j 2>/dev/null \
            | jq --arg name "$name" \
                '[.[] | select(.name == $name and .disabled != true)] | length'
    )"

    if test "${exists:-0}" -ne 1; then
        printf 'ACTIVE DISPLAY OUTPUT NOT FOUND\n'
        return 1
    fi

    hyprctl dispatch focusmonitor "$name" >/dev/null 2>&1 || {
        printf 'HYPRLAND COULD NOT FOCUS THE DISPLAY\n'
        return 1
    }

    printf 'DISPLAY FOCUSED: %s\n' "$name"
}

ensure_style_source() {
    local source_line='source = ~/.config/hypr/conf.d/chroma-style.conf'

    mkdir -p "$(dirname "$hyprland_config")" "$(dirname "$style_config")"
    touch "$hyprland_config"

    if ! grep -Fqx "$source_line" "$hyprland_config" 2>/dev/null; then
        printf '\n%s\n' "$source_line" >> "$hyprland_config"
    fi
}

style_sync() {
    local preset="${1:-SHARP}"
    local border_size="${2:-1}"
    local rounding

    preset="$(printf '%s' "$preset" | tr '[:lower:]' '[:upper:]')"

    case "$preset" in
        TECHNICAL)
            rounding=4
            ;;
        SOFT)
            rounding=12
            ;;
        CAPSULE)
            rounding=18
            ;;
        HYBRID)
            rounding=8
            ;;
        *)
            preset=SHARP
            rounding=0
            ;;
    esac

    case "$border_size" in
        0|1|2|3)
            ;;
        *)
            border_size=1
            ;;
    esac

    ensure_style_source

    cat > "$style_config" <<EOF
# CHROMA managed window geometry
# Generated $(date --iso-8601=seconds)

# Matches Hyprland client geometry to the active CHROMA style preset.
general {
    border_size = $border_size
}

decoration {
    rounding = $rounding
    rounding_power = 2
}
EOF

    hyprctl keyword general:border_size "$border_size" >/dev/null 2>&1 || true
    hyprctl keyword decoration:rounding "$rounding" >/dev/null 2>&1 || true
    hyprctl keyword decoration:rounding_power 2 >/dev/null 2>&1 || true

    printf 'STYLE SYNCED: %s / ROUNDING %s / BORDER %s\n' \
        "$preset" "$rounding" "$border_size"
}


json_result() {
    local ok="$1"
    local message="$2"

    jq -n \
        --argjson ok "$ok" \
        --arg message "$message" \
        '{ok:$ok,message:$message}'
}

normalise_desktop_id() {
    local value="${1:-}"

    value="$(basename -- "$value")"
    if test -n "$value" && [[ "$value" != *.desktop ]]; then
        value="${value}.desktop"
    fi

    printf '%s\n' "$value"
}

application_data_dirs() {
    local path
    local seen=':'
    local defaults=(
        "$home/.local/share"
        "$home/.nix-profile/share"
        "/etc/profiles/per-user/${USER:-$(id -un)}/share"
        "/run/current-system/sw/share"
        "/nix/var/nix/profiles/default/share"
        "$home/.local/share/flatpak/exports/share"
        "/var/lib/flatpak/exports/share"
        "/usr/local/share"
        "/usr/share"
    )

    IFS=':' read -r -a configured <<<"${XDG_DATA_DIRS:-}"

    for path in "${defaults[@]}" "${configured[@]}"; do
        test -n "$path" || continue
        case "$seen" in
            *:"$path":*)
                continue
                ;;
        esac
        seen="${seen}${path}:"
        printf '%s\n' "$path"
    done
}

locate_desktop_entry() {
    local id
    local data_dir candidate

    id="$(normalise_desktop_id "${1:-}")"
    test -n "$id" || return 1

    while IFS= read -r data_dir; do
        candidate="$data_dir/applications/$id"
        if test -f "$candidate"; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done < <(application_data_dirs)

    return 1
}

backup_application_file() {
    local source="$1"
    local label="$2"
    local stamp target

    test -f "$source" || return 0

    stamp="$(date +%Y%m%d-%H%M%S)-$$-$RANDOM"
    target="$applications_backups/${stamp}-${label}"
    cp -a "$source" "$target"
}

desktop_entry_enabled() {
    local file="$1"

    awk -F= '
        BEGIN { hidden = "false"; enabled = "true" }
        /^[[:space:]]*Hidden[[:space:]]*=/ {
            value = tolower($2)
            gsub(/[[:space:]]/, "", value)
            hidden = value
        }
        /^[[:space:]]*X-GNOME-Autostart-enabled[[:space:]]*=/ {
            value = tolower($2)
            gsub(/[[:space:]]/, "", value)
            enabled = value
        }
        END { exit ! (hidden != "true" && enabled != "false") }
    ' "$file"
}

applications_json() {
    local browser files editor autostart_json
    local file id
    local enabled=()

    if command -v xdg-mime >/dev/null 2>&1; then
        browser="$(xdg-mime query default text/html 2>/dev/null || true)"
        files="$(xdg-mime query default inode/directory 2>/dev/null || true)"
        editor="$(xdg-mime query default text/plain 2>/dev/null || true)"
    else
        browser=""
        files=""
        editor=""
    fi

    if test -d "$autostart_root"; then
        while IFS= read -r -d '' file; do
            if desktop_entry_enabled "$file"; then
                id="$(basename -- "$file")"
                enabled+=("$id")
            fi
        done < <(
            find "$autostart_root" \
                -maxdepth 1 \
                -type f \
                -name '*.desktop' \
                -print0 \
                2>/dev/null \
                | sort -z
        )
    fi

    if test "${#enabled[@]}" -gt 0; then
        autostart_json="$(printf '%s\n' "${enabled[@]}" | jq -R -s 'split("\n") | map(select(length > 0))')"
    else
        autostart_json='[]'
    fi

    jq -n \
        --arg browser "$browser" \
        --arg files "$files" \
        --arg editor "$editor" \
        --arg mimeapps "$mimeapps_file" \
        --argjson autostart "$autostart_json" \
        '{ok:true,defaults:{browser:$browser,files:$files,editor:$editor},autostart:$autostart,mimeapps:$mimeapps}'
}

application_set_default() {
    local role="${1:-}"
    local requested_id="${2:-}"
    local id source
    local mime_types=()
    local mime

    id="$(normalise_desktop_id "$requested_id")"
    source="$(locate_desktop_entry "$id" 2>/dev/null || true)"

    if test -z "$id" || test -z "$source"; then
        json_result false "DESKTOP ENTRY COULD NOT BE LOCATED"
        return 1
    fi

    case "$role" in
        terminal)
            ;;
        browser)
            mime_types=(text/html x-scheme-handler/http x-scheme-handler/https)
            ;;
        files)
            mime_types=(inode/directory)
            ;;
        editor)
            mime_types=(text/plain)
            ;;
        *)
            json_result false "UNKNOWN APPLICATION ROLE"
            return 1
            ;;
    esac

    if test "${#mime_types[@]}" -gt 0; then
        if ! command -v xdg-mime >/dev/null 2>&1; then
            json_result false "XDG MIME TOOLING IS UNAVAILABLE"
            return 1
        fi

        mkdir -p "$(dirname "$mimeapps_file")"
        backup_application_file "$mimeapps_file" "mimeapps.list"

        for mime in "${mime_types[@]}"; do
            if ! xdg-mime default "$id" "$mime" >/dev/null 2>&1; then
                json_result false "DEFAULT APPLICATION COULD NOT BE UPDATED"
                return 1
            fi
        done
    fi

    notify "${role^} application set to ${id%.desktop}"
    json_result true "${role^^} DEFAULT UPDATED"
}

rewrite_autostart_flags() {
    local source="$1"
    local target="$2"
    local enabled="$3"
    local temporary

    temporary="$(mktemp "${target}.tmp.XXXXXX")"

    awk '
        !/^[[:space:]]*Hidden[[:space:]]*=/ &&
        !/^[[:space:]]*X-GNOME-Autostart-enabled[[:space:]]*=/ &&
        !/^[[:space:]]*X-CHROMA-Managed[[:space:]]*=/ {
            print
        }
    ' "$source" > "$temporary"

    if test "$enabled" = "1"; then
        printf '\nHidden=false\nX-GNOME-Autostart-enabled=true\n' >> "$temporary"
    else
        printf '\nHidden=true\nX-GNOME-Autostart-enabled=false\n' >> "$temporary"
    fi
    printf 'X-CHROMA-Managed=true\n' >> "$temporary"

    chmod 0644 "$temporary"
    mv "$temporary" "$target"
}

application_autostart_set() {
    local requested_id="${1:-}"
    local enabled="${2:-}"
    local id source target input

    if ! [[ "$enabled" =~ ^[01]$ ]]; then
        json_result false "AUTOSTART VALUE FAILED VALIDATION"
        return 1
    fi

    id="$(normalise_desktop_id "$requested_id")"
    source="$(locate_desktop_entry "$id" 2>/dev/null || true)"
    target="$autostart_root/$id"

    if test -z "$id" || test -z "$source"; then
        json_result false "DESKTOP ENTRY COULD NOT BE LOCATED"
        return 1
    fi

    mkdir -p "$autostart_root"
    backup_application_file "$target" "$id"

    if test -f "$target"; then
        input="$target"
    else
        input="$source"
    fi

    rewrite_autostart_flags "$input" "$target" "$enabled"

    if test "$enabled" = "1"; then
        notify "Autostart enabled for ${id%.desktop}"
        json_result true "AUTOSTART ENABLED"
    else
        notify "Autostart disabled for ${id%.desktop}"
        json_result true "AUTOSTART DISABLED"
    fi
}

application_open_entry() {
    local requested_id="${1:-}"
    local id source target

    id="$(normalise_desktop_id "$requested_id")"
    source="$(locate_desktop_entry "$id" 2>/dev/null || true)"
    target="$home/.local/share/applications/$id"

    if test -z "$source"; then
        json_result false "DESKTOP ENTRY COULD NOT BE LOCATED"
        return 1
    fi

    mkdir -p "$(dirname "$target")"
    if test "$source" != "$target" && ! test -f "$target"; then
        cp -a "$source" "$target"
        chmod u+w "$target" 2>/dev/null || true
    fi

    backup_application_file "$target" "$id"
    open_file "$target"
    json_result true "EDITABLE DESKTOP ENTRY OPENED"
}

safe_label() {
    local value="${1:-snapshot}"

    value="$(printf '%s' "$value" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"

    printf '%s\n' "${value:-snapshot}"
}

snapshot_path_for_id() {
    local id="${1:-}"

    if test -z "$id" \
        || test "$id" != "$(basename -- "$id")" \
        || [[ "$id" != *.tar.gz ]]
    then
        return 1
    fi

    printf '%s/%s\n' "$snapshots" "$id"
}

snapshot_validate_archive() {
    local archive="${1:-}"
    local member_list verbose_list manifest archive_size

    test -f "$archive" || return 1

    archive_size="$(stat -c '%s' "$archive" 2>/dev/null || printf '0')"
    if test "$archive_size" -le 0 || test "$archive_size" -gt 536870912; then
        return 1
    fi

    member_list="$(mktemp "$config_root/members.XXXXXX")"
    verbose_list="$(mktemp "$config_root/verbose.XXXXXX")"

    if ! tar -tzf "$archive" > "$member_list" 2>/dev/null \
        || ! tar -tvzf "$archive" > "$verbose_list" 2>/dev/null
    then
        rm -f "$member_list" "$verbose_list"
        return 1
    fi

    if awk '
        /^\// { bad = 1 }
        /(^|\/)\.\.($|\/)/ { bad = 1 }
        $0 != "manifest.json" && $0 !~ /^payload(\/|$)/ { bad = 1 }
        END { exit bad ? 0 : 1 }
    ' "$member_list"
    then
        rm -f "$member_list" "$verbose_list"
        return 1
    fi

    if awk '
        substr($1, 1, 1) == "l" || substr($1, 1, 1) == "h" { bad = 1 }
        END { exit bad ? 0 : 1 }
    ' "$verbose_list"
    then
        rm -f "$member_list" "$verbose_list"
        return 1
    fi

    manifest="$(tar -xOzf "$archive" manifest.json 2>/dev/null || true)"
    rm -f "$member_list" "$verbose_list"

    jq -e '
        type == "object"
        and .type == "chroma-snapshot"
        and .schema == 1
        and (.createdAt | type == "string")
    ' >/dev/null 2>&1 <<<"$manifest"
}

snapshot_create() {
    local label="${1:-manual}"
    local stamp slug archive temporary staging payload created branch commit
    local entry basename_value

    stamp="$(date +%Y%m%d-%H%M%S)"
    slug="$(safe_label "$label")"
    archive="$snapshots/chroma-${slug}-${stamp}.tar.gz"
    temporary="${archive}.tmp.$$"
    staging="$(mktemp -d "$config_root/snapshot.XXXXXX")"
    payload="$staging/payload"
    created="$(date --iso-8601=seconds)"

    mkdir -p \
        "$payload/Projects/chroma-shell" \
        "$payload/.config/hypr/conf.d" \
        "$payload/.local/share/chroma-settings" \
        "$payload/.local/bin"

    if ! tar -C "$project" \
        --exclude='./.git' \
        --exclude='./.qmlls.ini' \
        --exclude='./backups' \
        --exclude='./result' \
        --exclude='./result-*' \
        --exclude='./.cache' \
        --exclude='*.bak' \
        --exclude='*.bak.*' \
        --exclude='*.broken' \
        --exclude='*.broken.*' \
        -cf - . 2>/dev/null \
        | tar -C "$payload/Projects/chroma-shell" -xf -
    then
        rm -rf "$staging"
        return 1
    fi

    if test -d "$xdg_config/chroma"; then
        mkdir -p "$payload/.config"
        cp -a "$xdg_config/chroma" "$payload/.config/"
    fi

    if test -d "$xdg_config/chroma-wallpaper"; then
        mkdir -p "$payload/.config"
        cp -a "$xdg_config/chroma-wallpaper" "$payload/.config/"
    fi

    if test -d "$xdg_config/hypr/conf.d"; then
        find "$xdg_config/hypr/conf.d" \
            -maxdepth 1 \
            -type f \
            -name 'chroma-*.conf' \
            -exec cp -a {} "$payload/.config/hypr/conf.d/" \;
    fi

    if test -d "$settings_root"; then
        while IFS= read -r -d '' entry; do
            basename_value="$(basename -- "$entry")"
            case "$basename_value" in
                snapshots|config)
                    continue
                    ;;
            esac
            cp -a "$entry" "$payload/.local/share/chroma-settings/"
        done < <(find "$settings_root" -mindepth 1 -maxdepth 1 -print0)
    fi

    if test -d "$home/.local/bin"; then
        find "$home/.local/bin" \
            -maxdepth 1 \
            -type f \
            -name 'chroma-*' \
            -exec cp -a {} "$payload/.local/bin/" \;
    fi

    branch="$(git -C "$project" branch --show-current 2>/dev/null || true)"
    commit="$(git -C "$project" rev-parse --short HEAD 2>/dev/null || true)"

    jq -n \
        --arg type "chroma-snapshot" \
        --argjson schema 1 \
        --arg id "$(basename -- "$archive")" \
        --arg label "$label" \
        --arg createdAt "$created" \
        --arg hostname "$(hostname 2>/dev/null || printf unknown)" \
        --arg branch "$branch" \
        --arg commit "$commit" \
        '{type:$type,schema:$schema,id:$id,label:$label,createdAt:$createdAt,hostname:$hostname,git:{branch:$branch,commit:$commit}}' \
        > "$staging/manifest.json"

    if ! tar -czf "$temporary" -C "$staging" manifest.json payload; then
        rm -rf "$staging"
        rm -f "$temporary"
        return 1
    fi

    mv "$temporary" "$archive"
    rm -rf "$staging"
    printf '%s\n' "$archive"
}

snapshots_json() {
    local archive manifest size modified valid
    local rows

    rows="$(mktemp "$config_root/snapshots.XXXXXX")"

    while IFS= read -r -d '' archive; do
        size="$(stat -c '%s' "$archive" 2>/dev/null || printf '0')"
        modified="$(date -d "@$(stat -c '%Y' "$archive" 2>/dev/null || printf '0')" --iso-8601=seconds 2>/dev/null || true)"

        if snapshot_validate_archive "$archive"; then
            valid=true
            manifest="$(tar -xOzf "$archive" manifest.json 2>/dev/null)"
            jq -c \
                --arg id "$(basename -- "$archive")" \
                --argjson size "$size" \
                --arg modifiedAt "$modified" \
                '. + {id:$id,size:$size,modifiedAt:$modifiedAt,valid:true}' \
                <<<"$manifest" >> "$rows"
        else
            valid=false
            jq -nc \
                --arg id "$(basename -- "$archive")" \
                --argjson size "$size" \
                --arg modifiedAt "$modified" \
                '{id:$id,label:"INVALID ARCHIVE",createdAt:$modifiedAt,modifiedAt:$modifiedAt,size:$size,valid:false,git:{branch:"",commit:""}}' \
                >> "$rows"
        fi
    done < <(
        find "$snapshots" \
            -maxdepth 1 \
            -type f \
            -name '*.tar.gz' \
            -print0 \
            2>/dev/null \
            | sort -z -r
    )

    jq -s '.' "$rows"
    rm -f "$rows"
}

config_file_json() {
    local id="$1"
    local label="$2"
    local path="$3"
    local kind="${4:-file}"
    local exists=false valid=true size=0

    if test -e "$path"; then
        exists=true
        size="$(du -sb "$path" 2>/dev/null | awk '{print $1}' || printf '0')"
    fi

    case "$id" in
        settings)
            if test "$exists" = true && ! jq -e 'type == "object"' "$path" >/dev/null 2>&1; then
                valid=false
            fi
            ;;
        backend)
            if test "$exists" = true && ! bash -n "$path" >/dev/null 2>&1; then
                valid=false
            fi
            ;;
    esac

    jq -nc \
        --arg id "$id" \
        --arg label "$label" \
        --arg path "$path" \
        --arg kind "$kind" \
        --argjson exists "$exists" \
        --argjson valid "$valid" \
        --argjson size "${size:-0}" \
        '{id:$id,label:$label,path:$path,kind:$kind,exists:$exists,valid:$valid,size:$size}'
}

config_status_json() {
    local branch commit remote dirty instances settings_valid backend_valid
    local errors warnings style_preset colour_treatment qml_version hyprland_version
    local files_json

    branch="$(git -C "$project" branch --show-current 2>/dev/null || printf 'not-a-repository')"
    commit="$(git -C "$project" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
    remote="$(git -C "$project" remote get-url origin 2>/dev/null || printf 'none')"
    dirty="$(git -C "$project" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
    instances="$("$project/preview.sh" status 2>/dev/null | awk '/CHROMA instances:/ {print $3; exit}')"
    : "${instances:=0}"

    settings_valid=false
    if test -f "$settings_file" && jq -e 'type == "object"' "$settings_file" >/dev/null 2>&1; then
        settings_valid=true
    fi

    backend_valid=false
    if bash -n "$project/backend/chroma-settingsctl" >/dev/null 2>&1; then
        backend_valid=true
    fi

    errors="$(tail -n 500 "$preview_log" 2>/dev/null | grep -Ec 'ERROR:|SyntaxError|Type .* unavailable' || true)"
    warnings="$(tail -n 500 "$preview_log" 2>/dev/null | grep -Ec 'WARN' || true)"
    style_preset="$(jq -r '.style.preset // "UNKNOWN"' "$settings_file" 2>/dev/null || printf 'UNKNOWN')"
    colour_treatment="$(jq -r '.style.colorTreatment // "UNKNOWN"' "$settings_file" 2>/dev/null || printf 'UNKNOWN')"
    qml_version="$(quickshell --version 2>/dev/null | head -n1 || printf 'unknown')"
    hyprland_version="$(hyprctl version 2>/dev/null | awk 'NR==1 {print; exit}')"
    : "${hyprland_version:=unknown}"

    files_json="$({
        config_file_json settings "CHROMA settings" "$settings_file"
        config_file_json style "Hyprland style" "$style_config"
        config_file_json displays "Display layout" "$display_config"
        config_file_json wallpaper "Wallpaper configuration" "$wallpaper_root" directory
        config_file_json backend "Settings backend" "$project/backend/chroma-settingsctl"
        config_file_json log "Runtime log" "$preview_log"
    } | jq -s '.')"

    jq -n \
        --arg branch "$branch" \
        --arg commit "$commit" \
        --arg remote "$remote" \
        --argjson dirty "${dirty:-0}" \
        --argjson instances "${instances:-0}" \
        --argjson settingsValid "$settings_valid" \
        --argjson backendValid "$backend_valid" \
        --argjson errors "${errors:-0}" \
        --argjson warnings "${warnings:-0}" \
        --arg stylePreset "$style_preset" \
        --arg colourTreatment "$colour_treatment" \
        --arg quickshell "$qml_version" \
        --arg hyprland "$hyprland_version" \
        --argjson files "$files_json" \
        '{ok:true,git:{branch:$branch,commit:$commit,remote:$remote,dirty:$dirty},runtime:{instances:$instances,errors:$errors,warnings:$warnings,quickshell:$quickshell,hyprland:$hyprland},configuration:{settingsValid:$settingsValid,backendValid:$backendValid,stylePreset:$stylePreset,colourTreatment:$colourTreatment},files:$files}'
}

config_path_for_id() {
    case "${1:-}" in
        settings) printf '%s\n' "$settings_file" ;;
        style) printf '%s\n' "$style_config" ;;
        displays) printf '%s\n' "$display_config" ;;
        wallpaper) printf '%s\n' "$wallpaper_root" ;;
        backend) printf '%s\n' "$project/backend/chroma-settingsctl" ;;
        log) printf '%s\n' "$preview_log" ;;
        project) printf '%s\n' "$project" ;;
        snapshots) printf '%s\n' "$snapshots" ;;
        *) return 1 ;;
    esac
}

config_open() {
    local path

    path="$(config_path_for_id "${1:-}" 2>/dev/null || true)"
    if test -z "$path"; then
        printf 'UNKNOWN CONFIGURATION TARGET\n'
        return 1
    fi

    if test -d "$path"; then
        open_path "$path"
    else
        open_file "$path"
    fi

    printf 'OPENED: %s\n' "$path"
}

config_copy_path() {
    local path

    path="$(config_path_for_id "${1:-}" 2>/dev/null || true)"
    if test -z "$path"; then
        printf 'UNKNOWN CONFIGURATION TARGET\n'
        return 1
    fi

    if ! command -v wl-copy >/dev/null 2>&1; then
        printf 'WL-COPY IS UNAVAILABLE\n'
        return 1
    fi

    printf '%s' "$path" | wl-copy
    printf 'COPIED PATH: %s\n' "$path"
}

config_validate() {
    local failures=0
    local source_line

    printf '=== CHROMA CONFIGURATION VALIDATION ===\n'

    if test -f "$settings_file" && jq -e 'type == "object"' "$settings_file" >/dev/null 2>&1; then
        printf 'PASS  settings JSON\n'
    else
        printf 'FAIL  settings JSON\n'
        failures=$((failures + 1))
    fi

    if bash -n "$project/backend/chroma-settingsctl" >/dev/null 2>&1; then
        printf 'PASS  backend Bash syntax\n'
    else
        printf 'FAIL  backend Bash syntax\n'
        failures=$((failures + 1))
    fi

    for source_line in \
        "$project/shell.qml" \
        "$project/SettingsWindow.qml" \
        "$project/settings/pages/ConfigPage.qml"
    do
        if test -s "$source_line"; then
            printf 'PASS  %s\n' "${source_line#$project/}"
        else
            printf 'FAIL  %s\n' "${source_line#$project/}"
            failures=$((failures + 1))
        fi
    done

    if git -C "$project" diff --check >/dev/null 2>&1; then
        printf 'PASS  Git whitespace\n'
    else
        printf 'FAIL  Git whitespace\n'
        failures=$((failures + 1))
    fi

    if test -f "$style_config"; then
        printf 'PASS  Hyprland style fragment\n'
    else
        printf 'WARN  Hyprland style fragment is missing\n'
    fi

    if test -f "$display_config"; then
        printf 'PASS  display fragment\n'
    else
        printf 'WARN  display fragment is missing\n'
    fi

    printf '\nRESULT: %s FAILURE(S)\n' "$failures"
    test "$failures" -eq 0
}

snapshot_delete() {
    local id="${1:-}"
    local archive

    archive="$(snapshot_path_for_id "$id" 2>/dev/null || true)"
    if test -z "$archive" || ! test -f "$archive"; then
        printf 'SNAPSHOT NOT FOUND\n'
        return 1
    fi

    rm -f -- "$archive"
    printf 'SNAPSHOT DELETED: %s\n' "$id"
}

snapshot_export() {
    local id="${1:-}"
    local archive target

    archive="$(snapshot_path_for_id "$id" 2>/dev/null || true)"
    if test -z "$archive" || ! snapshot_validate_archive "$archive"; then
        printf 'VALID SNAPSHOT NOT FOUND\n'
        return 1
    fi

    mkdir -p "$home/Downloads"
    target="$home/Downloads/$id"
    cp -a "$archive" "$target"
    printf 'SNAPSHOT EXPORTED: %s\n' "$target"
}

snapshot_import() {
    local requested="${1:-}"
    local source basename_value target stamp

    requested="${requested#file://}"
    if [[ "$requested" == '~/'* ]]; then
        requested="$home/${requested:2}"
    fi

    source="$requested"
    if test -z "$source" || ! snapshot_validate_archive "$source"; then
        printf 'IMPORT ARCHIVE FAILED VALIDATION\n'
        return 1
    fi

    basename_value="$(basename -- "$source")"
    basename_value="$(safe_label "${basename_value%.tar.gz}").tar.gz"
    target="$snapshots/$basename_value"

    if test -e "$target"; then
        stamp="$(date +%Y%m%d-%H%M%S)"
        target="$snapshots/${basename_value%.tar.gz}-${stamp}.tar.gz"
    fi

    cp -a "$source" "$target"
    printf 'SNAPSHOT IMPORTED: %s\n' "$(basename -- "$target")"
}

restore_replace_directory() {
    local payload="$1"
    local relative="$2"
    local source="$payload/$relative"
    local destination="$home/$relative"

    test -e "$source" || return 0
    rm -rf -- "$destination"
    mkdir -p "$(dirname "$destination")"
    cp -a "$source" "$destination"
}

snapshot_restore() {
    local id="${1:-}"
    local archive staging payload pre_restore entry basename_value

    archive="$(snapshot_path_for_id "$id" 2>/dev/null || true)"
    if test -z "$archive" || ! snapshot_validate_archive "$archive"; then
        printf 'VALID SNAPSHOT NOT FOUND\n'
        return 1
    fi

    pre_restore="$(snapshot_create pre-restore)" || {
        printf 'PRE-RESTORE SNAPSHOT COULD NOT BE CREATED\n'
        return 1
    }

    staging="$(mktemp -d "$config_restore_root/restore.XXXXXX")"
    if ! tar --no-same-owner --no-same-permissions -xzf "$archive" -C "$staging"; then
        rm -rf "$staging"
        printf 'SNAPSHOT COULD NOT BE EXTRACTED\n'
        return 1
    fi

    payload="$staging/payload"
    if ! test -d "$payload/Projects/chroma-shell"; then
        rm -rf "$staging"
        printf 'SNAPSHOT PROJECT PAYLOAD IS MISSING\n'
        return 1
    fi

    find "$project" \
        -mindepth 1 \
        -maxdepth 1 \
        ! -name '.git' \
        -exec rm -rf -- {} +
    cp -a "$payload/Projects/chroma-shell/." "$project/"

    restore_replace_directory "$payload" ".config/chroma"
    restore_replace_directory "$payload" ".config/chroma-wallpaper"

    if test -d "$payload/.config/hypr/conf.d"; then
        mkdir -p "$xdg_config/hypr/conf.d"
        find "$xdg_config/hypr/conf.d" \
            -maxdepth 1 \
            -type f \
            -name 'chroma-*.conf' \
            -delete
        cp -a "$payload/.config/hypr/conf.d/." "$xdg_config/hypr/conf.d/"
    fi

    if test -d "$payload/.local/share/chroma-settings"; then
        while IFS= read -r -d '' entry; do
            basename_value="$(basename -- "$entry")"
            rm -rf -- "$settings_root/$basename_value"
            cp -a "$entry" "$settings_root/"
        done < <(
            find "$payload/.local/share/chroma-settings" \
                -mindepth 1 \
                -maxdepth 1 \
                -print0
        )
    fi

    if test -d "$payload/.local/bin"; then
        mkdir -p "$home/.local/bin"
        cp -a "$payload/.local/bin/." "$home/.local/bin/"
    fi

    rm -rf "$staging"

    if ! bash -n "$project/backend/chroma-settingsctl" >/dev/null 2>&1; then
        printf 'RESTORE COMPLETED WITH A BACKEND SYNTAX WARNING\n'
        printf 'PRE-RESTORE SNAPSHOT: %s\n' "$pre_restore"
        return 1
    fi

    notify "Snapshot restored; restart CHROMA when ready"
    printf 'SNAPSHOT RESTORED: %s\n' "$id"
    printf 'PRE-RESTORE SNAPSHOT: %s\n' "$pre_restore"
    printf 'RESTART CHROMA TO LOAD THE RESTORED SOURCE\n'
}

case "${1:-help}" in
    style-sync)
        shift
        style_sync "$@"
        ;;

    system-json)
        system_json
        ;;

    display-json)
        hyprctl monitors all -j 2>/dev/null             | jq 'sort_by([.disabled, .x, .y, .name])'
        ;;

    display-preview)
        shift
        display_preview "$@"
        ;;

    display-keep)
        shift
        display_keep "$@"
        ;;

    display-revert)
        shift
        display_revert "$@"
        ;;

    display-known-good)
        display_known_good
        ;;

    display-restore-known-good)
        display_restore_known_good
        ;;

    display-focus)
        shift
        display_focus "$@"
        ;;

    applications-json)
        applications_json
        ;;

    application-set-default)
        shift
        application_set_default "$@"
        ;;

    application-autostart-set)
        shift
        application_autostart_set "$@"
        ;;

    application-open-entry)
        shift
        application_open_entry "$@"
        ;;

    config-status-json)
        config_status_json
        ;;

    config-validate)
        config_validate
        ;;

    config-open)
        shift
        config_open "$@"
        ;;

    config-copy-path)
        shift
        config_copy_path "$@"
        ;;

    snapshots-json)
        snapshots_json
        ;;

    snapshot-create)
        archive="$(snapshot_create "${2:-manual}")" || exit 1
        printf 'SNAPSHOT CREATED: %s\n' "$archive"
        notify "Snapshot created: $(basename -- "$archive")"
        ;;

    snapshot-restore)
        shift
        snapshot_restore "$@"
        ;;

    snapshot-delete)
        shift
        snapshot_delete "$@"
        ;;

    snapshot-export)
        shift
        snapshot_export "$@"
        ;;

    snapshot-import)
        shift
        snapshot_import "$@"
        ;;

    open-project)
        open_path "$project"
        printf 'Opened %s\n' "$project"
        ;;

    open-hyprland)
        open_file "$home/.config/hypr/hyprland.conf"
        printf 'Opened Hyprland configuration\n'
        ;;

    open-nixos)
        open_path /etc/nixos
        printf 'Opened /etc/nixos\n'
        ;;

    open-state)
        open_path "$xdg_state/quickshell"
        printf 'Opened Quickshell state directory\n'
        ;;

    open-log)
        if command -v kitty >/dev/null 2>&1; then
            kitty --hold bash -lc "tail -n 240 '$state/preview.log'; exec bash" >/dev/null 2>&1 &
        else
            open_file "$state/preview.log"
        fi
        printf 'Opened CHROMA runtime log\n'
        ;;

    open-wallpaper)
        open_path "$xdg_config/chroma-wallpaper"
        printf 'Opened wallpaper configuration\n'
        ;;

    open-display-config)
        open_file "$display_config"
        printf 'Opened display configuration fragment\n'
        ;;

    reload-hyprland)
        hyprctl reload >/dev/null 2>&1
        printf 'Hyprland configuration reloaded\n'
        notify "Hyprland reloaded"
        ;;

    restart-shell)
        "$project/preview.sh" restart >/dev/null 2>&1
        printf 'CHROMA restart requested\n'
        ;;

    health)
        report
        ;;

    snapshot)
        archive="$(snapshot_create manual)" || exit 1
        printf 'SNAPSHOT CREATED: %s\n' "$archive"
        notify "Snapshot created: $(basename -- "$archive")"
        ;;

    copy-report)
        text="$(report)"
        printf '%s\n' "$text" | wl-copy
        printf 'Diagnostic report copied to clipboard\n'
        notify "Diagnostic report copied"
        ;;

    copy-monitors)
        hyprctl monitors all -j 2>/dev/null | jq . | wl-copy
        printf 'Monitor report copied to clipboard\n'
        notify "Monitor report copied"
        ;;

    open-backups)
        open_path "$backups"
        printf 'Opened backup root\n'
        ;;

    *)
        printf '%s\n' \
            'Usage: chroma-settingsctl {' \
            'style-sync|system-json|display-json|display-preview|display-keep|' \
            'display-revert|display-known-good|display-restore-known-good|' \
            'display-focus|applications-json|application-set-default|' \
            'application-autostart-set|application-open-entry|' \
            'config-status-json|config-validate|config-open|config-copy-path|' \
            'snapshots-json|snapshot-create|snapshot-restore|snapshot-delete|' \
            'snapshot-export|snapshot-import|open-project|' \
            'open-hyprland|open-nixos|' \
            'open-state|open-log|open-wallpaper|open-display-config|' \
            'reload-hyprland|restart-shell|health|snapshot|' \
            'copy-report|copy-monitors|open-backups}'
        ;;
esac
